# ── Ports ────────────────────────────────────────────────────────────────────
# Backend FastAPI port
BACKEND_PORT=8000
# Frontend Vite dev server port (also set VITE_PORT for vite.config.ts)
VITE_PORT=5173
VITE_BACKEND_PORT=8000

# ── LLM ──────────────────────────────────────────────────────────────────────
# Default model via LiteLLM. Options: claude-haiku-3-5 | gpt-4o-mini | ollama/codellama
LITELLM_MODEL=claude-haiku-3-5

# API keys — only the one matching your model is required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Max tokens sent to LLM per query (hard budget cap)
MAX_CONTEXT_TOKENS=4000

# ── Storage ───────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
PROJECTS_TMP_DIR=/tmp/codebase_analyzer
PROJECTS_DATA_DIR=./data/projects
DATABASE_URL=sqlite+aiosqlite:///./data/analyzer.db

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
