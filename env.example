# ── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=9000
VITE_PORT=5173
VITE_BACKEND_PORT=89000

# ── LLM ──────────────────────────────────────────────────────────────────────
# Model name via LiteLLM routing.
# Built-in providers:  claude-haiku-3-5 | gpt-4o-mini
# Custom OpenAI-compatible: openai/<model-name>  (set LLM_API_BASE + LLM_API_KEY)
LITELLM_MODEL=openai/gpt-4o-mini

# Standard provider keys (used when LLM_API_KEY is not set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Custom OpenAI-compatible provider ────────────────────────────────────────
# Leave blank to use the standard OpenAI/Anthropic endpoints above.
# Example providers:
#   Together AI:  https://api.together.xyz/v1
#   Groq:         https://api.groq.com/openai/v1
#   Ollama:       http://localhost:11434/v1
#   LM Studio:    http://localhost:1234/v1
#   Azure OpenAI: https://<resource>.openai.azure.com
LLM_API_BASE=
LLM_API_KEY=

# Max tokens sent to LLM per query (hard budget cap)
MAX_CONTEXT_TOKENS=4000

# ── Storage ───────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
PROJECTS_TMP_DIR=./data/source
PROJECTS_DATA_DIR=./data/projects
DATABASE_URL=sqlite+aiosqlite:///./data/analyzer.db

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
